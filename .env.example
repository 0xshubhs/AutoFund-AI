# AutoFund AI — all optional. With NONE set, the zero-config demo still works:
# every route degrades to a deterministic mock / heuristic / dry-run, and the
# `source` field on every response reports provenance honestly.

# --- OpenAI copilot (Task 1) -------------------------------------------------
# When OPENAI_API_KEY is set, the analyst copilot + decision-reason enrichment
# run on OpenAI Chat Completions. Without it, a deterministic heuristic is used
# and no route ever claims "AI live".
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional OpenAI-compatible gateway base URL (leave blank for real OpenAI):
# OPENAI_BASE_URL=

# --- On-chain reads (Task 2) — keyless, FREE, no web3 dep --------------------
# These default to the public mainnet endpoints; override only if needed.
# VALUECHAIN_RPC_URL=https://rpc.valuechain.xyz          # chainId 286623 (SOSO gas)
# VALUECHAIN_TESTNET_RPC_URL=https://testnet-rpc.valuechain.xyz  # chainId 138565
# BASE_RPC_URL=https://mainnet.base.org                  # chainId 8453
# Verified SoSoValue MAG7.ssi index token on Base (symbol "MAG7.ssi", decimals 8).
# Override to read a different ERC-20; leave default for the verified one.
# SSI_TOKEN_ADDRESS=0x9E6A46f294bB67c20F1D1E7AfB0bBEf614403B55

# --- MarketMind coupling (Task 3) — optional ingest --------------------------
# Provide a marketmind.autofund.signal/v1 JSON inline or via URL to auto-feed
# its contradiction flag + conviction into the risk gate. (Can also be pasted
# in the UI on the Risk Engine page.) If unset, AutoFund behaves as today.
# MARKETMIND_SIGNAL_JSON={"schema":"marketmind.autofund.signal/v1","conviction":0.8,"contradiction":true,"recommendedAction":"reduce-risk"}
# MARKETMIND_SIGNAL_URL=

# --- SoSoValue API (Wave 2) --------------------------------------------------
SOSO_API_KEY=
# SOSO_BASE_URL=https://openapi.sosovalue.com/openapi/v1
# SOSO_NEWS_PATH=/news/list
# SOSO_SECTOR_PATH=/currency/sector-spotlight
# SOSO_ETF_PATH=/etfs/summary-history

# --- SoDEX (Wave 2) — dry-run unless a key is present ------------------------
SODEX_API_KEY=
# SODEX_BASE_URL=https://testnet-gw.sodex.dev/api/v1/spot
# SODEX_ORDER_PATH=/trade/orders/batch
# SODEX_CHAIN_ID=138565
# SODEX_DOMAIN_NAME=spot
# SODEX_EXPLORER=
